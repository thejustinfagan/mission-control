# NVIDIA NIM API key for executive briefing + future AI features.
# Get one at https://build.nvidia.com — never commit the real key.
NVIDIA_API_KEY=

# Optional: override the default model (meta/llama-3.1-8b-instruct)
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Persisted SQLite database. Railway production should mount a volume at /data.
# MC_DB_PATH=/data/mission-control.db

# Human/UI Basic Auth. Required outside the narrow public /api/health endpoint.
MC_UI_USERNAME=
MC_UI_PASSWORD=

# Agent push auth for approved agents and scripts. Required; there is no fallback.
MC_AUTH_TOKEN=

# Primary Barry integration: POST /api/agents/feed after every action
# See protocols/barry-feeds-mission-control.md and scripts/barry-feed-mc.sh

# GitHub API token (optional — raises rate limits for proof-card commit/CI slots)
# GITHUB_TOKEN=

# HTTP reachability probes override: projectId|https://url,...
# Optional render probes override: projectId|url|marker1;marker2
# MC_RENDER_PROBES=fleet-intel|https://fleetintel.net|fleet;carrier
