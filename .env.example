# NVIDIA NIM API key for executive briefing + future AI features.
# Get one at https://build.nvidia.com — never commit the real key.
NVIDIA_API_KEY=

# Optional: override the default model (meta/llama-3.1-8b-instruct)
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Agent push auth — Barry/Harry send Bearer token on heartbeat + activity POSTs
MC_AUTH_TOKEN=

# GitHub API token (optional — raises rate limits for proof-card commit/CI slots)
# GITHUB_TOKEN=

# HTTP reachability probes: projectId|https://url,projectId|https://url
# MC_PROBE_URLS=mission-control|https://your-app.up.railway.app/api/status

# Persisted stores (defaults to /tmp on Railway)
# MC_HEARTBEAT_STORE_PATH=/tmp/mission-control-heartbeats.json
# MC_ACTIVITIES_STORE_PATH=/tmp/mission-control-activities.json
